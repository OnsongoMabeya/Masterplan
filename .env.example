# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=30d
COOKIE_SECRET=replace_with_another_long_random_string

# Database
DB_CLIENT=better-sqlite3
DB_FILENAME=./backend/database/masterplan.db

# PostgreSQL (production) - uncomment when needed
# DB_CLIENT=pg
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=masterplan
# DB_USER=postgres
# DB_PASSWORD=your_password
