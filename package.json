{
  "name": "masterplan-pwa",
  "version": "1.0.0",
  "description": "30-Year Life Masterplan PWA - Personal planning dashboard with offline support",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon backend/server.js",
    "dev:frontend": "vite frontend",
    "dev:all": "bash scripts/dev.sh",
    "build": "bash scripts/build.sh",
    "start": "NODE_ENV=production node backend/server.js",
    "migrate": "knex --knexfile backend/knexfile.js migrate:latest",
    "migrate:rollback": "knex --knexfile backend/knexfile.js migrate:rollback",
    "seed": "node backend/database/seeds/run-seed.js",
    "setup": "npm run migrate && npm run seed",
    "db:migrate": "knex migrate:latest --knexfile backend/knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile backend/knexfile.js",
    "db:seed": "knex seed:run --knexfile backend/knexfile.js",
    "db:reset": "npm run db:rollback && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "express": "^4.18.2",
    "knex": "^3.1.0",
    "better-sqlite3": "^9.4.3",
    "pg": "^8.11.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "zod": "^3.22.4",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "morgan": "^1.10.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^0.19.2",
    "workbox-window": "^7.0.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
